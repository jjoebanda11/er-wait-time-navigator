# ER Wait Time Navigator — environment configuration
#
# EVERY VARIABLE HERE IS OPTIONAL.
#
# With a completely empty .env the app still runs and delivers its core value:
# live wait times for all of Alberta, door-to-doctor ranking, the triage tool,
# the alternative care directory, offline support, and PWA install. That is a
# deliberate design constraint so the business can launch with no accounts and
# no spend. Everything below is an upgrade that switches itself on when its
# credentials appear.
#
# Copy to .env.local for development, or paste into Vercel's project settings.

# ---------------------------------------------------------------------------
# Site identity — set this first
# ---------------------------------------------------------------------------
# Used for canonical URLs, the sitemap, and social share cards. Without it,
# search engines will index localhost URLs. No leading slash on the end.
NEXT_PUBLIC_SITE_URL=https://your-domain.ca

# Shown on the legal and contact pages. Use a real, monitored address —
# correction reports about a health tool need to reach a human.
NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.ca

# Appears in the copyright line and legal pages. Once the business is
# registered in Alberta, put the exact registered name here.
NEXT_PUBLIC_LEGAL_ENTITY=ER Wait Time Navigator

# ---------------------------------------------------------------------------
# Database — enables historical trends and "best time to go"
# ---------------------------------------------------------------------------
# Any Postgres works. Neon and Supabase both have genuinely free tiers that fit
# this workload comfortably. Apply the schema first:
#   psql "$DATABASE_URL" -f src/lib/db/schema.sql
#
# Leave unset and the trends pages honestly say history is still building,
# while everything else works normally.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ---------------------------------------------------------------------------
# Scheduled capture
# ---------------------------------------------------------------------------
# Shared secret protecting /api/cron/snapshot. Required if you drive captures
# from GitHub Actions (see .github/workflows/capture-snapshot.yml), which is the
# recommended free approach — Vercel's Hobby plan only allows DAILY cron and
# will fail the build on anything more frequent.
#
# Generate one:  openssl rand -hex 32
# CRON_SECRET=

# ---------------------------------------------------------------------------
# Web push — enables wait-threshold alerts
# ---------------------------------------------------------------------------
# Free, no third-party account needed. Generate a VAPID key pair with:
#   npx web-push generate-vapid-keys
#
# Requires DATABASE_URL as well; alerts need somewhere to store rules.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@your-domain.ca

# ---------------------------------------------------------------------------
# Drive-time accuracy (optional upgrade)
# ---------------------------------------------------------------------------
# Without either key, drive times are estimated on-device from distance and
# calibrated speeds. That is accurate enough to rank correctly and costs
# nothing, which is why it is the default.
#
# OpenRouteService: free tier, 2,000 requests/day, NO credit card required.
# Adds real road routing. This is the recommended first upgrade.
# ORS_API_KEY=
#
# Google Routes API: the only option with live traffic. Requires a billing
# account. Only worth enabling once revenue supports it.
# GOOGLE_ROUTES_API_KEY=

# ---------------------------------------------------------------------------
# Billing — BUILT BUT DARK
# ---------------------------------------------------------------------------
# The subscription system is complete and tested, but stays switched off unless
# BILLING_ENABLED is explicitly true AND a Stripe secret key is present. Both
# are required, so a stray key in the environment can never begin charging
# people by accident.
#
# Do not turn this on until the business is registered and insured.
BILLING_ENABLED=false
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PLUS_MONTHLY=
# STRIPE_PRICE_PLUS_ANNUAL=
# STRIPE_PRICE_FAMILY_MONTHLY=
# STRIPE_PRICE_FAMILY_ANNUAL=
